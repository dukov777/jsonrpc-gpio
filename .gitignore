# Generated by Cargo / rustc
/target/
debug/

# This is a binary crate, so Cargo.lock IS committed (not ignored).

# rustfmt backups
**/*.rs.bk

*.pdb

# RLS / rust-analyzer
*.rls
rust-project.json

# ESP-IDF / embuild — downloaded SDK, build cache, generated bindings
/.embuild/
sdkconfig
sdkconfig.old

# macOS
.DS_Store

# Python client venv / caches
__pycache__/
*.pyc
.venv/

# Claude Code dir: track only the shared ESP32 footprint hooks. Everything else
# is local/per-machine — nested git worktrees, personal settings, the size
# baseline, and local logs must never be committed.
/.claude/*
!/.claude/hooks/
